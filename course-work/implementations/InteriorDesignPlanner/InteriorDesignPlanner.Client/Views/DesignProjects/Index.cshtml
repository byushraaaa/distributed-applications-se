@model List<InteriorDesignPlanner.Client.Models.DesignProjectViewModel>

@{
    ViewData["Title"] = "Design Projects";
}

<h2>Design Projects</h2>

<a asp-controller="Rooms"
   asp-action="Index"
   class="btn btn-secondary mb-3">
    Rooms
</a>

<a asp-action="Create"
   class="btn btn-primary mb-3">
    Create Project
</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Style</th>
            <th>Room Type</th>
            <th>Budget</th>
            <th>Created At</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var project in Model)
        {
            <tr>
                <td>@project.Title</td>
                <td>@project.Description</td>
                <td>@project.Style</td>
                <td>@project.RoomType</td>
                <td>@project.Budget</td>
                <td>@project.CreatedAt</td>
                <td>
                    <a asp-action="Edit"
                       asp-route-id="@project.Id"
                       class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@project.Id"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>