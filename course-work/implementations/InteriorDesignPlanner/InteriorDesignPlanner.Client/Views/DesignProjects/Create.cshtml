@model InteriorDesignPlanner.Client.Models.DesignProjectViewModel

@{
    ViewData["Title"] = "Create Design Project";
}

<h2>Create Design Project</h2>

<form asp-action="Create">

    <div class="mb-3">
        <label>Title</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Description</label>
        <input asp-for="Description" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Style</label>
        <input asp-for="Style" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Room Type</label>
        <input asp-for="RoomType" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Budget</label>
        <input asp-for="Budget" class="form-control" />
    </div>

    <button type="submit" class="btn btn-success">
        Create
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Back
    </a>
</form>