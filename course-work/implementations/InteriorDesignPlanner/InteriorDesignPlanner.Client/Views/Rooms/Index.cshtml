@model List<InteriorDesignPlanner.Client.Models.RoomViewModel>

@{
    ViewData["Title"] = "Rooms";
}

<h2>Rooms</h2>

<a asp-controller="Auth"
   asp-action="Logout"
   class="btn btn-danger mb-3">
    Logout
</a>

<a asp-action="Create"
   class="btn btn-primary mb-3">
    Create Room
</a>

<table class="table table-bordered table-striped">

    <thead>
        <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Size</th>
            <th>Style</th>
            <th>Budget</th>
            <th>Created At</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var room in Model)
        {
            <tr>
                <td>@room.Name</td>
                <td>@room.Type</td>
                <td>@room.Size</td>
                <td>@room.Style</td>
                <td>@room.Budget</td>
                <td>@room.CreatedAt</td>

                <td>

                    <a asp-action="Edit"
                       asp-route-id="@room.Id"
                       class="btn btn-warning btn-sm">
                        Edit
                    </a>

                    <a asp-action="Delete"
                       asp-route-id="@room.Id"
                       class="btn btn-danger btn-sm">
                        Delete
                    </a>

                </td>

            </tr>
        }

    </tbody>

</table>